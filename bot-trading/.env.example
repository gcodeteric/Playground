# ── Interactive Brokers ──────────────────────────
IB_HOST=127.0.0.1
PAPER_TRADING=true
USE_GATEWAY=false
IB_CLIENT_ID=1
# Porta selecionada automaticamente:
# PAPER+TWS=7497 | PAPER+GW=4002 | LIVE+TWS=7496 | LIVE+GW=4001
IB_PORT=

# ── Capital ──────────────────────────────────────
INITIAL_CAPITAL=100000.0

# ── Watchlist ────────────────────────────────────
WATCHLIST=AAPL,SPY,QQQ

# ── Risco ────────────────────────────────────────
RISK_PER_LEVEL=0.01
DAILY_LOSS_LIMIT=0.03
WEEKLY_LOSS_LIMIT=0.06
MONTHLY_DD_LIMIT=0.10
MAX_POSITIONS=8
MAX_GRIDS=3
MIN_RR=2.5
STOP_ATR_MULT=1.0
TP_ATR_MULT=2.5
KELLY_CAP=0.05
GRID_RECENTER_PCT=0.70

# ── Telegram (opcional) ──────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Bot ──────────────────────────────────────────
CYCLE_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
# DATA_DIR=./data
